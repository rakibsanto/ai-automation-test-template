# QA Template Configuration

# 1. Project Information (Used for report titles and organization)
PROJECT_NAME=My Awesome Project

# 2. Environment URLs
# The base URL of the staging or production environment to test against
BASE_URL=https://dev.prowhats.com/en

# 3. Test Credentials (Used by AI for login flows)
TEST_USERNAME=qa_test_user@example.com
TEST_PASSWORD=qa_test_password123

# 4. Optional Configurations
# Set HEADED=1 to see the browser window during testing, 0 to run invisibly
HEADED=1

# Set the AI Model to use for generating tests
AI_MODEL=qwen2.5-coder:1.5b
